{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "files": [
    "src/features/research/topic-explorer/topic-explorer-logic.ts",
    "src/features/research/topic-explorer/TopicExplorer.tsx",
    "src/lib/bkend.ts",
    "src/types/topic-exploration.ts",
    "src/features/research/__tests__/topic-explorer-logic.test.ts"
  ]
}