{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "files": [
    "src/components/mypage/MyResearchView.tsx",
    "src/features/research/topic-explorer/topic-explorer-logic.ts",
    "src/features/research/topic-explorer/TopicExplorer.tsx",
    "src/features/research/ThesisJourney.tsx",
    "src/features/research/ResearchJourneyGuide.tsx",
    "src/components/home/ResearchJourneySection.tsx",
    "src/features/dashboard/VacationModeCard.tsx",
    "src/lib/onboarding-next-cta.ts",
    "src/components/layout/command-routes.ts"
  ]
}