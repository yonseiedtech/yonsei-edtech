rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /inquiries/{inquiryId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /seminars/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /seminar_sessions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /seminar_attendees/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /seminar_registrations/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /certificates/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
