rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isStaffOrAbove() {
      let role = getUserRole();
      return role in ['staff', 'president', 'admin', 'sysadmin'];
    }
    function isAdmin() {
      let role = getUserRole();
      return role == 'admin' || role == 'sysadmin';
    }
    // Checks that sensitive fields (role, approved) are not modified
    function noSensitiveFieldChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'approved']);
    }
    // 활동의 모임장(leaderId)이 현재 사용자인지 — Sprint 1~5 (Study Enhancement)
    // staff가 아닌 모임장이 회차 회고·과제·노트 운영 권한을 가지려면 필요.
    function isActivityLeader(activityId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/activities/$(activityId))
        && get(/databases/$(database)/documents/activities/$(activityId)).data.leaderId == request.auth.uid;
    }

    // ─── Users ───
    match /users/{userId} {
      // Public profile (QR scan) — single-doc get is open; list still requires auth
      allow get: if true;
      allow list: if isAuthenticated();
      // 회원가입: 본인이 본인 문서를 처음 만드는 경우 허용 (role=member, approved=false 강제)
      allow create: if isOwner(userId)
        && request.resource.data.role == 'member'
        && request.resource.data.approved == false;
      // Users can update their own profile, but NOT role or approved
      allow update: if isOwner(userId) && noSensitiveFieldChange();
      // Only admin can delete users or change role/approved
      allow delete: if isAuthenticated() && isAdmin();
      // Admin can create/update anything
      allow create, update: if isAuthenticated() && isAdmin();
    }

    // ─── Posts ───
    // board-community-v2: 카테고리별 read/write 권한 재검증
    function postCategoryReadable(cat) {
      // staff/resources는 인증 필요, 그 외 public
      // paper_review (Sprint 41d): 교육공학 논문 리뷰 — public read
      return cat in ['notice', 'seminar', 'free', 'promotion', 'press', 'interview', 'paper_review']
        || (cat == 'resources' && isAuthenticated())
        || (cat == 'staff' && isAuthenticated() && isStaffOrAbove());
    }
    function postCategoryWritable(cat) {
      // free / paper_review: 회원 누구나 작성 가능
      return (cat in ['free', 'paper_review'] && isAuthenticated())
        || (cat in ['notice', 'seminar', 'promotion', 'resources', 'staff', 'press', 'interview']
            && isAuthenticated() && isStaffOrAbove());
    }
    // viewCount 1 증가 단일 필드 update — 비로그인 포함 누구나 허용 (조회수 집계용)
    function isViewCountOnlyIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;
    }
    // Sprint 67-AO: reactionCount 단일 필드 변경 (+1 또는 -1) — 인증 회원 허용
    function isReactionCountOnlyChange() {
      return isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactionCount'])
        && (
          request.resource.data.reactionCount == (resource.data.get('reactionCount', 0) + 1)
          || request.resource.data.reactionCount == (resource.data.get('reactionCount', 0) - 1)
        );
    }
    match /posts/{postId} {
      allow read: if postCategoryReadable(resource.data.category);
      // 카테고리별 쓰기 권한 재검증
      allow create: if isAuthenticated()
        && postCategoryWritable(request.resource.data.category)
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isViewCountOnlyIncrement()
        || isReactionCountOnlyChange()
        || (isAuthenticated()
          && (resource.data.authorId == request.auth.uid || isStaffOrAbove())
          && postCategoryWritable(request.resource.data.category));
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove())
        && postCategoryWritable(resource.data.category);

      // 좋아요 (uid를 doc id로 사용 → 중복 방지)
      match /likes/{uid} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && request.auth.uid == uid;
      }
      // 투표 (익명 모드에서는 client가 해시를 doc id로)
      match /votes/{voteKey} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated(); // editableUntil 검증은 API/클라이언트
        allow delete: if false; // 투표는 삭제 불가
      }
      // 댓글
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
      }
    }

    // ─── Comments ───
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Inquiries ───
    match /inquiries/{inquiryId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow create: if true; // Public contact form
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Site Settings (admin/president only) ───
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated()
        && getUserRole() in ['president', 'admin', 'sysadmin'];
    }

    // ─── Seminars ───
    match /seminars/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Sessions ───
    match /seminar_sessions/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Attendees ───
    match /seminar_attendees/{docId} {
      allow read: if true;
      // Authenticated users can register themselves
      allow create: if isAuthenticated();
      // Only self or staff+ can update/delete
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Seminar Registrations ───
    match /seminar_registrations/{docId} {
      allow read: if isAuthenticated();
      allow create: if true; // Public registration
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Certificates ───
    match /certificates/{docId} {
      // 본인(recipientUserId) 또는 staff 이상만 read. 공개 조회는 차단.
      allow read: if isAuthenticated()
        && (resource.data.recipientUserId == request.auth.uid || isStaffOrAbove());
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Promotion Contents ───
    match /promotion_contents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Materials ───
    match /seminar_materials/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Reviews ───
    match /seminar_reviews/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Chat Logs & Q&A ───
    match /chat_logs/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && isStaffOrAbove();
    }

    match /chat_qa/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Activities (프로젝트, 스터디, 대외활동) ───
    match /activities/{docId} {
      // 회원 본인이 참가/취소 신청 시 applicants/participants 만 수정
      function isApplyOnlyUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['applicants', 'participants', 'updatedAt']);
      }
      // 비회원 게스트 신청 시 applicants 만 수정
      function isGuestApplyUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['applicants', 'updatedAt']);
      }
      allow read: if true;
      allow create, delete: if isAuthenticated() && isStaffOrAbove();
      allow update: if (isAuthenticated() && isStaffOrAbove())
        || (isAuthenticated() && isApplyOnlyUpdate())
        || isGuestApplyUpdate();
    }

    // ─── Fee Settings (학회비 설정) ───
    match /fee_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Fee Payments (학회비 납부 기록) ───
    match /fee_payments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Newsletters (학회보) ───
    match /newsletters/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Activity Progress (활동 진행현황) ───
    match /activity_progress/{docId} {
      function isActivityLeader(activityId) {
        let act = get(/databases/$(database)/documents/activities/$(activityId));
        return isAuthenticated() && act.data.leaderId == request.auth.uid;
      }
      allow read: if isAuthenticated();
      // 운영진 또는 해당 활동의 모임장(leaderId)
      allow create: if isAuthenticated() && (isStaffOrAbove() || isActivityLeader(request.resource.data.activityId));
      allow update, delete: if isAuthenticated() && (isStaffOrAbove() || isActivityLeader(resource.data.activityId));
    }

    // ─── Activity Materials (활동 자료) ───
    match /activity_materials/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Progress Meetings (실시간 미팅 타이머) ───
    match /progress_meetings/{docId} {
      function isMeetingActivityLeader(activityId) {
        let act = get(/databases/$(database)/documents/activities/$(activityId));
        return isAuthenticated() && act.data.leaderId == request.auth.uid;
      }
      // 인증된 사용자는 누구나 라이브 미팅 조회 가능 (참여자가 같이 보면서 회의 진행)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isStaffOrAbove() || isMeetingActivityLeader(request.resource.data.activityId));
      allow update, delete: if isAuthenticated() && (isStaffOrAbove() || isMeetingActivityLeader(resource.data.activityId));
    }

    // ─── Email Logs (이메일 발송 기록) ───
    match /email_logs/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Notifications (알림) ───
    match /notifications/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Admin Todos (할일) ───
    match /admin_todos/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Polls (투표) ───
    match /polls/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isStaffOrAbove();
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Poll Responses (투표 응답) ───
    match /poll_responses/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Photo Albums (갤러리 앨범) ───
    match /photo_albums/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Photos (갤러리 사진) ───
    match /photos/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.uploadedBy == request.auth.uid || isStaffOrAbove());
    }

    // ─── Seminar Waitlist (세미나 대기자) ───
    match /seminar_waitlist/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Business Card Exchanges (명함 교환 로그) ───
    match /business_card_exchanges/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
          || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.receiverId == request.auth.uid
        && request.resource.data.ownerId != request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.resource.data.ownerId))
        && get(/databases/$(database)/documents/users/$(request.resource.data.ownerId)).data.name == request.resource.data.ownerName;
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Interview Responses (온라인 인터뷰 응답) ───
    match /interview_responses/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.respondentId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.respondentId == request.auth.uid || isStaffOrAbove());
      allow delete: if isAuthenticated()
        && (resource.data.respondentId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Interview Response Reactions (좋아요/멋져요) ───
    match /interview_response_reactions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Interview Response Comments (댓글 CRUD) ───
    match /interview_response_comments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Research Papers (개인 논문 분석 노트) ───
    match /research_papers/{docId} {
      // 운영진(staff 이상)은 회원 연구활동 어드민 화면에서 전체 조회 필요
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Writing Papers (내가 쓰는 논문 — 사용자당 1건 단일 문서) ───
    match /writing_papers/{docId} {
      // 운영진(staff 이상)은 /console/research 어드민에서 회원 작성 논문 조회 필요
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Defense Practice Sets (논문 심사 연습 Q&A 세트) ───
    match /defense_practice_sets/{docId} {
      // 개인 학습 자료 — 본인 + 관리자(admin)만 read. staff/president는 접근 불가
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Defense Question Templates (운영진이 사전 등록하는 질문 템플릿) ───
    match /defense_question_templates/{docId} {
      // 회원 누구나 읽고 자기 세트에 import 가능, 작성/수정/삭제는 관리자(admin)만
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ─── Writing Paper History (작성 활동 이력 — 잔디/통계용, append-only) ───
    match /writing_paper_history/{docId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      // 이력은 변경/삭제 불가 (감사성)
      allow update, delete: if false;
    }

    // ─── Research Reports (연구 보고서 — 사용자당 1건) ───
    match /research_reports/{docId} {
      // 운영진(staff 이상)은 /console/research 어드민에서 회원 보고서를 조회해야 함
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Research Proposals (연구 계획서 — 사용자당 1건) ───
    match /research_proposals/{docId} {
      // 운영진(staff 이상)은 /console/research 어드민에서 회원 계획서를 조회해야 함
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Study Sessions (연구 타이머 세션 — 통계/잔디용) ───
    match /study_sessions/{docId} {
      // 운영진(staff 이상)은 회원 누적 시간/세션 통계 조회 필요
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Profile Likes (PR5 — 프로필 좋아요, 1인 1회 보장) ───
    match /profile_likes/{docId} {
      // 카운트/누가 눌렀는지 조회는 로그인 회원만
      allow read: if isAuthenticated();
      // doc id는 결정적 `${profileId}_${likerId}` — 본인만 자기 좋아요 생성/삭제
      allow create: if isAuthenticated()
        && request.resource.data.likerId == request.auth.uid
        && docId == request.resource.data.profileId + "_" + request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.likerId == request.auth.uid;
      allow update: if false;
    }

    // ─── Profile Views (PR5 — 통계용 페이지 뷰) ───
    match /profile_views/{docId} {
      // 본인 페이지의 view 통계는 본인만 열람
      allow read: if isAuthenticated() && resource.data.profileId == request.auth.uid;
      // 비로그인 외부인도 view 로깅은 가능 (운영진 페이지 등 public 접근 케이스)
      allow create: if true;
      allow update, delete: if false;
    }

    // ─── Audit Logs (감사 로그) ───
    match /audit_logs/{docId} {
      allow read: if isAuthenticated()
        && getUserRole() in ['president', 'admin', 'sysadmin'];
      allow create: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Activity Participations (Track 2: 학술활동 이력) ───
    match /activity_participations/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
    }

    // ─── Awards (수상 이력) ───
    match /awards/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
    }

    // ─── External Activities (외부 학술활동, 운영진 검증 큐) ───
    match /external_activities/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
      // 본인은 verificationStatus를 변경할 수 없음 — staff만 검증 가능
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid
          && request.resource.data.verificationStatus == resource.data.verificationStatus)
        || isStaffOrAbove()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
    }

    // ─── Content Creations (저작/콘텐츠 활동) ───
    match /content_creations/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffOrAbove()
      );
    }

    // ─── Alumni Theses (졸업생 학위논문 DB) ───
    match /alumni_theses/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Thesis References (학위논문 참고문헌, V2) ───
    match /thesis_references/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Thesis Claims (본인 논문 클레임, 운영진 검증 큐) ───
    match /thesis_claims/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && isStaffOrAbove();
      allow delete: if false;
    }

    // ─── Course Offerings (Track 5: 학기별 개설 과목 마스터) ───
    match /course_offerings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Course Enrollments (Track 5: 과목별 수강생 명단 — 운영진 관리 + 본인 자율 표시) ───
    match /course_enrollments/{docId} {
      allow read: if isAuthenticated();

      // 생성: 운영진 자유 / 본인은 자기 수강(student)·청강(auditor) 표시만
      allow create: if isAuthenticated() && (
        isStaffOrAbove() || (
          request.resource.data.userId == request.auth.uid
          && request.resource.data.role in ['student', 'auditor']
        )
      );

      // 수정: 운영진 자유 / 본인은 자기 role 전환(student↔auditor) 한정
      allow update: if isAuthenticated() && (
        isStaffOrAbove() || (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role in ['student', 'auditor']
        )
      );

      // 삭제: 운영진 자유 / 본인 자기 기록 삭제(해제) 가능
      allow delete: if isAuthenticated() && (
        isStaffOrAbove() || resource.data.userId == request.auth.uid
      );
    }

    // ─── Guide Tracks (Track 6: 인지디딤판 트랙 카탈로그) ───
    match /guide_tracks/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Guide Items (Track 6: 가이드 항목 — published만 공개) ───
    match /guide_items/{docId} {
      allow read: if resource.data.published == true
        || (isAuthenticated() && isStaffOrAbove());
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Guide Progress (Track 6: 회원 체크리스트 진행 상태) ───
    match /guide_progress/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Site Popups (사이트 팝업 공지) ───
    // 비로그인자도 active 팝업을 조회할 수 있어야 게이트가 작동
    match /site_popups/{docId} {
      allow read: if true;
      allow write: if isAuthenticated()
        && getUserRole() in ['president', 'admin', 'sysadmin'];
    }

    // ─── Card News Series (인스타그램 카드뉴스) ───
    // 운영진이 편집·발행하면 비로그인 방문자도 슬라이더로 볼 수 있어야 함
    match /card_news_series/{docId} {
      allow read: if true;
      allow write: if isAuthenticated()
        && getUserRole() in ['president', 'admin', 'sysadmin'];
    }

    // ─── Host Retrospectives (Track 7 F6: 호스트 회고) ───
    // 작성/수정/삭제: 호스트 본인만
    // 열람: 호스트 본인 + 운영진(published만)
    match /host_retrospectives/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.hostUserId == request.auth.uid
            || (resource.data.status == 'published' && isStaffOrAbove()));
      allow create: if isAuthenticated()
        && request.resource.data.hostUserId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.hostUserId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.hostUserId == request.auth.uid;
    }

    // ─── Handover Docs (업무 인수인계 문서) ───
    // 운영진 이상만 read/write (민감 운영 노하우 포함)
    match /handover_docs/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Class Sessions (수업 일정/차시) ───
    // 수강생·회원 누구나 read, 운영진만 write
    match /class_sessions/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Course Session Notes (수강생 개인 수업 메모) ───
    // 본인만 read/write (운영진이라도 타인의 개인 메모는 접근 불가)
    match /course_session_notes/{docId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Course Todos (수강생 개인 해야할 일) ───
    // 본인만 read/write
    match /course_todos/{docId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Course Reviews (강의 후기) ───
    // 공개 read (수강 선택 참고), 작성자 본인만 update (helpful 토글 포함)
    // helpfulBy[] toggle은 본인이 아닌 사용자도 허용 (rating/comment 불변)
    function isHelpfulToggleOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpfulCount', 'helpfulBy', 'updatedAt']);
    }
    match /course_reviews/{docId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isHelpfulToggleOnly() || isStaffOrAbove());
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Comprehensive Exam Records (종합시험 응시 기록) ───
    // 본인(userId) 또는 운영진만 read/write
    match /comprehensive_exam_records/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow create: if isAuthenticated()
        && (request.resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Grad Life Positions (대학원 생활 활동 이력 — 전공대표·조교·학회 운영진) ───
    // 회원 read 허용 (프로필 sectionVisibility로 클라이언트 게이트), staff만 write
    match /grad_life_positions/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Conference Programs (대외학술대회 시간표 v3) ───
    // 누구나 read (홍보), staff 이상이 write
    match /conference_programs/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── User Session Plans (회원 세션 선택·후기 v3) ───
    // 본인은 자신의 plan CRUD, 운영진은 통계용 read
    match /user_session_plans/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      // list (운영자 통계 / 본인 모아보기) — query 단에서 userId 필터를 강제
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Sprint 67-D: 받은 명함 (Received Business Cards) ───
    // 본인이 받은 명함만 본인이 read·write 가능 (privacy)
    match /received_business_cards/{docId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
    }

    // ─── Sprint 67-F: 학술대회 워크북 ───
    // 운영진이 과제 부여, 참여자(인증 사용자)는 read 가능
    match /conference_workbook_tasks/{docId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      // QA-F1: isAuthenticated() 전제 조건 명시 (다른 collection 과 일관성)
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }
    // 참여자 본인 제출만 본인이 read·write 가능, 운영진은 모두 read·feedback write 가능
    match /conference_workbook_submissions/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && (
          (resource.data.userId == request.auth.uid
            && request.resource.data.userId == request.auth.uid)
          || isStaffOrAbove()
        );
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
    // 학술대회 전체 후기
    match /conference_workbook_reviews/{docId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Sprint 67-Z: 학술대회 참석자 후기 ───
    // 회원이 학술대회 종료 후 작성하는 종합 후기.
    // - 모든 인증 회원이 read 가능 (개요 하단 표시용)
    // - 본인만 write 가능
    // - regrets 필드는 별도 collection (conference_attendee_review_regrets) 로 분리됨
    match /conference_attendee_reviews/{docId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Sprint 67-AO: 게시글 공감 reaction ───
    // 모든 인증 회원이 read·list 가능 (카운트 표시 + 본인 reaction 확인)
    // 본인만 write/delete 가능 (sysadmin 추가 권한 가능)
    match /post_reactions/{docId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Sprint 67-AJ: 학술대회 자원봉사자 배정 ───
    // 운영진(staff+)이 write, 본인은 read 가능. 모든 인증 사용자가 list 가능 (참여자 봉사 명단 확인용)
    match /volunteer_assignments/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // QA-H1: 아쉬운 점 (regrets) 별도 collection — 본인 + 운영진만 read.
    // 일반 conference_attendee_reviews 와 같은 ID ({userId}_{activityId}) 로 매칭.
    match /conference_attendee_review_regrets/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow list: if isAuthenticated() && isStaffOrAbove();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Labs (시크릿랩 프로젝트 카드) ───
    // 공개 read (디렉토리), 소유자(ownerId) 또는 운영진만 write
    match /labs/{docId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Lab Reactions (이모지 반응) ───
    match /lab_reactions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── Lab Comments ───
    match /lab_comments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Daily Visits (사이트 일별 방문 통계) ───
    // 모든 방문자(비로그인 포함)가 카운터 증가 가능. 통계 조회는 admin만.
    match /daily_visits/{day} {
      allow read: if isAuthenticated() && isAdmin();
      allow create, update: if true;
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ─── 교육공학 아카이브 (Concept / Variable / MeasurementTool) ───
    // 공개 read (탐색용), staff 이상이 write
    match /archive_concepts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }
    match /archive_variables/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }
    match /archive_measurements/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Archive Favorites (관심 저장) ───
    // 본인만 자신의 즐겨찾기 read/write. ID는 {userId}_{itemType}_{itemId} 형식.
    match /archive_favorites/{docId} {
      allow read, list: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Push Tokens (Sprint 53) ───
    // 클라이언트는 직접 read/write 불가 — /api/push/* 엔드포인트(Admin SDK)만 사용.
    // 모든 클라이언트 요청 차단으로 토큰 노출 방지. 운영진은 콘솔(Firestore)에서 직접 조회.
    match /push_tokens/{docId} {
      allow read, write: if false;
    }

    // ─── Push Logs (Sprint 53) ───
    // 발송 중복 방지용 — 클라이언트 read/write 차단, 서버(Admin SDK)만 사용.
    match /push_logs/{docId} {
      allow read, write: if false;
    }

    // ─── Counters (Sprint 69 — 트랜잭션 시퀀스 발급용) ───
    // 클라이언트는 read/write 불가. 서버(Admin SDK)만 사용. cert_YY 등.
    match /counters/{docId} {
      allow read, write: if false;
    }

    // ─── User Activity Logs (Sprint 63) ───
    // 회원 페이지 접속 이력 — admin 만 read. 본인은 자기 본인 userId 로만 create 가능.
    // update/delete 는 admin 만 (정리·수동 보정).
    match /user_activity_logs/{docId} {
      allow read, list: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ─── Yonsei Agent Jobs (학회 도메인 에이전트 v2) ───
    // 본인 작업만 read/list 가능. create/update/delete 는 모두 서버(Admin SDK)만 수행.
    // 칸반 페이지에서 onSnapshot 으로 실시간 구독.
    match /agent_jobs/{docId} {
      allow read, list: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // ─── Roadmap Stages (Sprint 67-AR — 학기별 로드맵 CMS) ───
    // 회원 read-only. 운영진(staff 이상)이 CRUD.
    match /roadmap_stages/{stageId} {
      allow read, list: if true; // 비로그인 포함 누구나 (학기별 로드맵은 공개 자료)
      allow create, update: if isAuthenticated() && isStaffOrAbove();
      allow delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── AI Forum (Sprint 67-AR — AI들끼리 자율 토론 게시판) ───
    // 회원 read-only. create/update 는 운영진(staff 이상). 메시지는 서버(Admin SDK)만 append.
    match /ai_forums/{forumId} {
      allow read, list: if isAuthenticated();
      allow create, update: if isAuthenticated() && isStaffOrAbove();
      allow delete: if isAuthenticated() && isAdmin();
    }
    match /ai_forum_messages/{messageId} {
      allow read, list: if isAuthenticated();
      allow create, update: if false; // 서버 cron tick 만 append
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ─── Study Session Reflections (Sprint 1 — Study Enhancement) ───
    // 회차 단위 개인 회고.
    // - read: 본인 + 운영진 (isPrivate=true 일 때도 운영진은 열람 가능; 모임장이 staff가 아닐 경우의 제약은 MVP 한계로 수용)
    // - write: 본인만
    match /study_session_reflections/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Study Assignments (Sprint 2 — Study Enhancement) ───
    // 과제 부여 권한 — staff 또는 해당 활동의 모임장(leader)
    // - create: payload 의 activityId 기준 leader 또는 staff
    // - update/delete: 기존 doc 의 activityId 기준 leader 또는 staff
    match /study_assignments/{docId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated()
        && (isStaffOrAbove() || isActivityLeader(request.resource.data.activityId));
      allow update, delete: if isAuthenticated()
        && (isStaffOrAbove() || isActivityLeader(resource.data.activityId));
    }

    // ─── Study Assignment Submissions (Sprint 2 — Study Enhancement) ───
    // 본인 제출 + 운영진/리더 피드백. staff 의 update 는 feedback 필드 화이트리스트 강제 (제출 위변조 방지)
    match /study_assignment_submissions/{docId} {
      allow read: if isAuthenticated()
        && (
          resource.data.userId == request.auth.uid
          || isStaffOrAbove()
          || isActivityLeader(resource.data.activityId)
        );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && (
          // 본인 — 자신의 제출만 수정 가능
          (resource.data.userId == request.auth.uid
            && request.resource.data.userId == request.auth.uid)
          // 운영진/리더 — feedback 관련 필드만 변경 가능 (제출 본문 위변조 방지)
          || (
            (isStaffOrAbove() || isActivityLeader(resource.data.activityId))
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['feedback', 'feedbackBy', 'feedbackByName', 'feedbackAt', 'updatedAt'])
          )
        );
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Study Session Notes (Sprint 4 — Study Enhancement) ───
    // 회차 토론 노트 (질문/인사이트/하이라이트/인용). 학습 공유 목적이라 전 회원 read.
    // 작성/수정은 본인만. 삭제는 본인 + 운영진(스팸/욕설 정리).
    match /study_session_notes/{docId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }
  }
}
