rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isStaffOrAbove() {
      let role = getUserRole();
      return role in ['staff', 'president', 'admin'];
    }
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    // Checks that sensitive fields (role, approved) are not modified
    function noSensitiveFieldChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'approved']);
    }

    // ─── Users ───
    match /users/{userId} {
      // Public profile (QR scan) — single-doc get is open; list still requires auth
      allow get: if true;
      allow list: if isAuthenticated();
      // Users can update their own profile, but NOT role or approved
      allow update: if isOwner(userId) && noSensitiveFieldChange();
      // Only admin can change role/approved or create/delete users
      allow create, delete: if isAuthenticated() && isAdmin();
      // Admin can update anything
      allow update: if isAuthenticated() && isAdmin();
    }

    // ─── Posts ───
    // board-community-v2: 카테고리별 read/write 권한 재검증
    function postCategoryReadable(cat) {
      // staff/resources는 인증 필요, 그 외 public
      return cat in ['notice', 'seminar', 'free', 'promotion', 'press', 'interview']
        || (cat == 'resources' && isAuthenticated())
        || (cat == 'staff' && isAuthenticated() && isStaffOrAbove());
    }
    function postCategoryWritable(cat) {
      return (cat == 'free' && isAuthenticated())
        || (cat in ['notice', 'seminar', 'promotion', 'resources', 'staff', 'press', 'interview']
            && isAuthenticated() && isStaffOrAbove());
    }
    match /posts/{postId} {
      allow read: if postCategoryReadable(resource.data.category);
      // 카테고리별 쓰기 권한 재검증
      allow create: if isAuthenticated()
        && postCategoryWritable(request.resource.data.category)
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove())
        && postCategoryWritable(request.resource.data.category);
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove())
        && postCategoryWritable(resource.data.category);

      // 좋아요 (uid를 doc id로 사용 → 중복 방지)
      match /likes/{uid} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && request.auth.uid == uid;
      }
      // 투표 (익명 모드에서는 client가 해시를 doc id로)
      match /votes/{voteKey} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated(); // editableUntil 검증은 API/클라이언트
        allow delete: if false; // 투표는 삭제 불가
      }
      // 댓글
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
      }
    }

    // ─── Comments ───
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Inquiries ───
    match /inquiries/{inquiryId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow create: if true; // Public contact form
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Site Settings (admin/president only) ───
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated()
        && getUserRole() in ['president', 'admin'];
    }

    // ─── Seminars ───
    match /seminars/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Sessions ───
    match /seminar_sessions/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Attendees ───
    match /seminar_attendees/{docId} {
      allow read: if true;
      // Authenticated users can register themselves
      allow create: if isAuthenticated();
      // Only self or staff+ can update/delete
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Seminar Registrations ───
    match /seminar_registrations/{docId} {
      allow read: if isAuthenticated();
      allow create: if true; // Public registration
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Certificates ───
    match /certificates/{docId} {
      // 본인(recipientUserId) 또는 staff 이상만 read. 공개 조회는 차단.
      allow read: if isAuthenticated()
        && (resource.data.recipientUserId == request.auth.uid || isStaffOrAbove());
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Promotion Contents ───
    match /promotion_contents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Materials ───
    match /seminar_materials/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Seminar Reviews ───
    match /seminar_reviews/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Chat Logs & Q&A ───
    match /chat_logs/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && isStaffOrAbove();
    }

    match /chat_qa/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Activities (프로젝트, 스터디, 대외활동) ───
    match /activities/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Fee Settings (학회비 설정) ───
    match /fee_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Fee Payments (학회비 납부 기록) ───
    match /fee_payments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Newsletters (학회보) ───
    match /newsletters/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Activity Progress (활동 진행현황) ───
    match /activity_progress/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Activity Materials (활동 자료) ───
    match /activity_materials/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Email Logs (이메일 발송 기록) ───
    match /email_logs/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Notifications (알림) ───
    match /notifications/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Admin Todos (할일) ───
    match /admin_todos/{docId} {
      allow read: if isAuthenticated() && isStaffOrAbove();
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Polls (투표) ───
    match /polls/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isStaffOrAbove();
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Poll Responses (투표 응답) ───
    match /poll_responses/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Photo Albums (갤러리 앨범) ───
    match /photo_albums/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Photos (갤러리 사진) ───
    match /photos/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.uploadedBy == request.auth.uid || isStaffOrAbove());
    }

    // ─── Seminar Waitlist (세미나 대기자) ───
    match /seminar_waitlist/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Business Card Exchanges (명함 교환 로그) ───
    match /business_card_exchanges/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
          || isStaffOrAbove());
      allow create: if isAuthenticated()
        && request.resource.data.receiverId == request.auth.uid
        && request.resource.data.ownerId != request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.resource.data.ownerId))
        && get(/databases/$(database)/documents/users/$(request.resource.data.ownerId)).data.name == request.resource.data.ownerName;
      allow update, delete: if isAuthenticated() && isStaffOrAbove();
    }

    // ─── Interview Responses (온라인 인터뷰 응답) ───
    match /interview_responses/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.respondentId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.respondentId == request.auth.uid || isStaffOrAbove());
      allow delete: if isAuthenticated()
        && (resource.data.respondentId == request.auth.uid || isStaffOrAbove());
    }

    // ─── Audit Logs (감사 로그) ───
    match /audit_logs/{docId} {
      allow read: if isAuthenticated()
        && getUserRole() in ['president', 'admin'];
      allow create: if isAuthenticated() && isStaffOrAbove();
    }
  }
}
